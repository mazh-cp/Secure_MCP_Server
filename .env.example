# Copy to .env (never commit) OR inject via your secrets manager / Vault at
# process start. All real values MUST come from the secrets store, not source.

# --- Identity & scopes ---
# Path to a JSON file (see identity.example.json) declaring this instance's
# caller_id and the tool scopes it is permitted to expose. Under stdio
# transport this is a deploy-time capability constraint, not per-request auth.
# One file per caller, named <caller_id>.json. Under the systemd template unit
# this is /etc/secure-mcp/identities/%i.json where %i is the caller_id.
SECURE_MCP_IDENTITY_FILE=/etc/secure-mcp/identities/soc-analyst.json

# --- Check Point Threat Emulation (cloud) ---
CHECKPOINT_TE_BASE_URL=https://te.checkpoint.com
CHECKPOINT_TE_API_KEY=__provide_via_vault__

# --- Lakera Guard ---
LAKERA_GUARD_BASE_URL=https://api.lakera.ai
LAKERA_GUARD_API_KEY=__provide_via_vault__

# --- Check Point ThreatCloud (reputation / categorization / phishing) ---
# Only required if a threat_intel / url_category / anti_phishing scope is
# granted. VERIFY the base URL against your subscription's reputation/IOC API.
CHECKPOINT_TC_BASE_URL=https://rep.checkpoint.com
CHECKPOINT_TC_API_KEY=__provide_via_vault__

# --- DLP egress filter ---
# block  = reject any text containing detected secrets/PII
# redact = replace matches with [REDACTED:type] before egress (default)
# flag   = pass through unchanged, record findings in the audit log
SECURE_MCP_DLP_MODE=redact

# --- Tamper-evident audit (HMAC key, hex or raw) ---
# When set, audit entries are HMAC-chained so edits/truncation are detectable
# via `python -m secure_mcp.audit_verify`. Inject from Vault/KMS. If unset the
# log falls back to a plain SHA-256 chain (weaker — logs a startup warning).
SECURE_MCP_AUDIT_HMAC_KEY=__provide_via_vault__

# --- Daily quota (per-process / per-caller call cap; 0 = unlimited) ---
SECURE_MCP_DAILY_QUOTA=0

# --- Operational config file (managed by the admin console) ---
# Non-secret operational knobs (dlp_mode, daily_quota, rate_limit_per_minute)
# written by the console; read by the MCP server at startup, overriding env.
# Secrets are NEVER stored here.
SECURE_MCP_CONFIG_FILE=/etc/secure-mcp/config.json

# --- Admin console (secure-mcp-admin) ---
# Bearer token for console sign-in. Inject from Vault/KMS — never hardcode.
SECURE_MCP_ADMIN_TOKEN=__provide_via_vault__
SECURE_MCP_ADMIN_HOST=127.0.0.1
SECURE_MCP_ADMIN_PORT=8765
# Directory of per-caller identity files the console manages.
SECURE_MCP_IDENTITY_DIR=/etc/secure-mcp/identities
# TLS for the console. REQUIRED to bind to any non-loopback host (fails closed).
SECURE_MCP_ADMIN_TLS_CERT=/etc/secure-mcp/tls/console.crt
SECURE_MCP_ADMIN_TLS_KEY=/etc/secure-mcp/tls/console.key
# Session lifetime (seconds) and separate admin-action audit log.
SECURE_MCP_ADMIN_SESSION_TTL=1800
SECURE_MCP_ADMIN_AUDIT_LOG=/var/log/secure-mcp/admin-audit.jsonl
# In-console restart (opt-in). Comma-separated ALLOWLIST of systemd units the
# console may restart — empty disables the feature. The console executes a
# fixed `systemctl restart <unit>` argv (no shell); the unit must be in this
# list. Grant narrow privilege via polkit/sudoers (see docs/CONSOLE.md).
# Each unit's instance name = caller_id, e.g. caller "soc-analyst" -> unit
# secure-mcp@soc-analyst.service (matches the polkit glob secure-mcp@*.service).
SECURE_MCP_MANAGED_UNITS=secure-mcp@soc-analyst.service,secure-mcp@triage.service
# Set true if the console user runs systemctl via `sudo -n` (NOPASSWD) instead
# of direct privilege.
SECURE_MCP_RESTART_USE_SUDO=false

# --- Edge PDP (secure-mcp-edge): internet-facing URL-verdict API for browsers ---
# Phase 1 is INDICATOR-ONLY (URL/domain/hash) — no file or AI-text content paths.
# Enrollment secret distributed to devices via MDM/GPO; never hardcode.
SECURE_MCP_EDGE_ENROLLMENT_SECRET=__provide_via_vault__
SECURE_MCP_EDGE_HOST=127.0.0.1
SECURE_MCP_EDGE_PORT=8770
# TLS REQUIRED to bind non-loopback (fails closed). Or terminate TLS at a
# reverse proxy and keep the bind on 127.0.0.1.
SECURE_MCP_EDGE_TLS_CERT=/etc/secure-mcp/tls/edge.crt
SECURE_MCP_EDGE_TLS_KEY=/etc/secure-mcp/tls/edge.key
# Device-token lifetime, per-group rate limit, optional daily quota.
SECURE_MCP_EDGE_TOKEN_TTL=3600
SECURE_MCP_EDGE_RATE_LIMIT_PER_MIN=120
SECURE_MCP_EDGE_DAILY_QUOTA=0
# Optional allowlist of permitted enrollment groups (comma-separated; empty=any).
SECURE_MCP_EDGE_GROUPS=
# Block "suspicious" classifications too (default: warn only).
SECURE_MCP_EDGE_BLOCK_SUSPICIOUS=false
# Separate hash-chained audit log for edge decisions.
SECURE_MCP_EDGE_AUDIT_LOG=/var/log/secure-mcp/edge-audit.jsonl
# Phase 2 — central policy authority. Per-group signed policy docs + the
# Ed25519 keypair the edge signs with. The admin console authors into the same
# policy dir (it never needs the private key); only the edge materializes it.
SECURE_MCP_EDGE_POLICY_DIR=/etc/secure-mcp/policies
SECURE_MCP_EDGE_KEYS_DIR=/etc/secure-mcp/keys

# --- Audit log sink (must be authorized + encrypted-at-rest storage) ---
SECURE_MCP_AUDIT_LOG_PATH=/var/log/secure-mcp/audit.jsonl

# --- Upload staging (transient buffers; purge after job) ---
SECURE_MCP_UPLOAD_DIR=/var/lib/secure-mcp/staging
SECURE_MCP_MAX_UPLOAD_BYTES=33554432

# --- Rate limiting (per-scope token bucket, in-memory) ---
# Cap on calls per minute per tool scope. Conservative default; raise as your
# upstream quota allows. Refill is steady (per_minute / 60 tokens per second).
SECURE_MCP_RATE_LIMIT_PER_MIN=60
